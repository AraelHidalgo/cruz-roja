// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionContent {
  id        String   @id @default(cuid())
  sectionId String   @unique // e.g. "hero", "corazon", "escudo"
  title     String?
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String?
  imageUrl    String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryPost {
  id          String   @id @default(cuid())
  text        String?
  imageUrls   String   // JSON stringified array of URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

